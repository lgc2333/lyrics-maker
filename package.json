{
  "name": "lyrics-maker",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier -cw .",
    "check": "vue-tsc -b",
    "test": "vitest",
    "test:run": "vitest run",
    "coverage": "vitest run --coverage",
    "deploy:cf": "pnpm run build && wrangler deploy"
  },
  "dependencies": {
    "@applemusic-like-lyrics/ttml": "^1.0.1",
    "@iconify/vue": "^5.0.1",
    "@libraz/libsonare": "^1.2.1",
    "@vueuse/core": "^14.3.0",
    "@xmldom/xmldom": "^0.9.10",
    "ass-compiler": "^0.1.16",
    "pinia": "^3.0.4",
    "vue": "^3.5.35",
    "vue-i18n": "^11.4.4",
    "vue-router": "^5.0.7",
    "wavesurfer.js": "^7.12.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@cloudflare/vite-plugin": "^1.39.0",
    "@tailwindcss/vite": "^4.3.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.9.1",
    "@upstash/context7-mcp": "^3.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.7",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "chrome-devtools-mcp": "^1.1.1",
    "daisyui": "^5.5.20",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.3.2",
    "wrangler": "^4.95.0"
  }
